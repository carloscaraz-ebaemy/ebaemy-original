# ============================================================================
# .env.production.example — Valores seguros recomendados para produccion
# Copiar a .env y ajustar los valores especificos del dominio/servidor.
# ============================================================================

APP_ENV=production
APP_DEBUG=false
APP_URL=https://yourdomain.com

# Forzar HTTPS en todas las URLs generadas por Laravel
FORCE_HTTPS=true

# Session — cifrado y cookies seguras
SESSION_DRIVER=redis
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_LIFETIME=30
SESSION_DOMAIN=.yourdomain.com

# CORS — restringir origenes permitidos (separados por coma)
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=warning

# Cache / Queue
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
